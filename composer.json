{
    "name": "sprintf/entity-table-bundle",
    "description": "Symfony Entity Table Bundle by Sprint-F.RU",
    "license": "BSD-3-Clause",
    "type": "symfony-bundle",
    "keywords": [
    ],
    "authors": [
        {
            "name": "Albert Stepantsev",
            "email": "albert.stepantsev@sprintf.ru"
        }
    ],
    "homepage": "https://sprintf.ru",
    "require": {
        "php": "^8.4",
        "sprintf/symfony-metadata-loader": "^1.2.1",
        "sprintf/value-objects": "*",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "symfony/property-access": "^7.4 || ^8.0",
        "symfony/translation": "^7.4 || ^8.0",
        "symfony/ux-twig-component": "^3.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.90"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "SprintF\\Bundle\\EntityTable\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        },
        "sort-packages": true
    }
}
